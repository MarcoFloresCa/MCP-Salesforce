# ============================================
# MCP Salesforce Reader - Configuration
# ============================================
#
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control!
#
# Format: SALESFORCE_<PREFIX>_<FIELD>=<VALUE>
# The system automatically detects orgs by finding variables ending in _ALIAS
#

# ============================================
# ORG 1: Sandbox Dev Example
# ============================================
SALESFORCE_BANAGRO_DEV_ALIAS=banagro-dev
SALESFORCE_BANAGRO_DEV_ENVIRONMENT=sandbox
SALESFORCE_BANAGRO_DEV_LOGIN_URL=https://test.salesforce.com
SALESFORCE_BANAGRO_DEV_USERNAME=your.username@dev.org
SALESFORCE_BANAGRO_DEV_PASSWORD=YOUR_PASSWORD
SALESFORCE_BANAGRO_DEV_SECURITY_TOKEN=YOUR_SECURITY_TOKEN

# ============================================
# ORG 2: Sandbox UAT Example
# ============================================
SALESFORCE_BANAGRO_UAT_ALIAS=banagro-uat
SALESFORCE_BANAGRO_UAT_ENVIRONMENT=sandbox
SALESFORCE_BANAGRO_UAT_LOGIN_URL=https://test.salesforce.com
SALESFORCE_BANAGRO_UAT_USERNAME=your.username@uat.org
SALESFORCE_BANAGRO_UAT_PASSWORD=YOUR_PASSWORD
SALESFORCE_BANAGRO_UAT_SECURITY_TOKEN=YOUR_SECURITY_TOKEN

# ============================================
# ORG 3: Production Example
# ============================================
SALESFORCE_BANAGRO_PROD_ALIAS=banagro-prod
SALESFORCE_BANAGRO_PROD_ENVIRONMENT=production
SALESFORCE_BANAGRO_PROD_LOGIN_URL=https://login.salesforce.com
SALESFORCE_BANAGRO_PROD_USERNAME=your.username@company.com
SALESFORCE_BANAGRO_PROD_PASSWORD=YOUR_PASSWORD
SALESFORCE_BANAGRO_PROD_SECURITY_TOKEN=YOUR_SECURITY_TOKEN

# ============================================
# SECURITY: Production Confirmation Token
# ============================================
# Required for accessing production orgs.
# Set a secure token that must be provided to confirm_production_access tool.
PRODUCTION_CONFIRMATION_TOKEN=your_secure_token_here

# ============================================
# DEFAULT ORG
# ============================================
# This org will be used as default if none specified
DEFAULT_ORG_ALIAS=banagro-dev

# ============================================
# LOGGING
# ============================================
# Options: debug, info, warn, error
LOG_LEVEL=info
