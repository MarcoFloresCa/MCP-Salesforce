# ============================================
# MCP Salesforce Reader - Configuration
# ============================================
#
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control!
#

# ============================================
# ORGS CONFIGURATION (JSON Array)
# ============================================
# Each org needs:
# - alias: unique identifier for this org
# - environment: "sandbox" or "production"
# - loginUrl: Salesforce login URL
# - username: Salesforce username
# - password: Salesforce password
# - securityToken: Salesforce security token
#
# IMPORTANT: Production orgs are always read-only!
#
SALESFORCE_ORGS_JSON='[
  {
    "alias": "dev",
    "environment": "sandbox",
    "loginUrl": "https://test.salesforce.com",
    "username": "your.username@dev.org",
    "password": "YOUR_PASSWORD",
    "securityToken": "YOUR_SECURITY_TOKEN"
  },
  {
    "alias": "uat",
    "environment": "sandbox",
    "loginUrl": "https://test.salesforce.com",
    "username": "your.username@uat.org",
    "password": "YOUR_PASSWORD",
    "securityToken": "YOUR_SECURITY_TOKEN"
  },
  {
    "alias": "prod",
    "environment": "production",
    "loginUrl": "https://login.salesforce.com",
    "username": "your.username@company.com",
    "password": "YOUR_PASSWORD",
    "securityToken": "YOUR_SECURITY_TOKEN"
  }
]'

# ============================================
# DEFAULT ORG
# ============================================
# This org will be used as default if none specified
DEFAULT_ORG_ALIAS=dev

# ============================================
# LOGGING
# ============================================
# Options: debug, info, warn, error
LOG_LEVEL=info
